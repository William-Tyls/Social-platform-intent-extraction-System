# CloakBrowser 应用层环境变量配置模板
#
# 用法: 复制本文件为 .env 并填入真实值:
#   cp tools/.env.example tools/.env
# .env 已被 .gitignore 忽略,不会提交。所有脚本启动时自动加载。
# 真实 shell 环境变量优先于 .env 中的值。

# ---- socks5_forwarder.py: 远程韩国 SOCKS5 代理 ----
CB_REMOTE_PROXY_HOST=101.55.16.42
CB_REMOTE_PROXY_PORT=1337
CB_REMOTE_PROXY_USER=your_user
CB_REMOTE_PROXY_PASS=your_pass

# ---- Twitter 账号密码(console.py 登录用) ----
# 变量名规则: CB_TWITTER_PASS_<账号名大写>,对应 config.json 里的 account.name
# 例如账号名 "KR_1" → CB_TWITTER_PASS_KR_1
CB_TWITTER_PASS_KR_1=your_password
CB_TWITTER_PASS_NORWAY_1=your_password

# ---- twitter_test.py / twitter_search_test.py ----
# WebRTC 伪装 IP(应与代理出口 IP 一致)
CB_WEBRTC_IP=101.55.16.42
# 代理地址(console.py 的方案里若选 socks5://127.0.0.1:11080 则用本地转发器)
CB_TWITTER_PROXY=socks5://127.0.0.1:11080

# ---- llm_filter.py / console.py LLM 过滤 ----
# DeepSeek API Key(console.py 优先读此变量,其次读 ~/.cloakbrowser_deepseek_key)
# ⚠️ 真实 key 只能写进 tools/.env(被 gitignore),不要写进本文件!本文件会被提交。
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ---- youtube_test.py / youtube_api.py ----
# YouTube Data API v3 密钥
# 申请步骤:
#   1. 前往 https://console.cloud.google.com/apis/credentials
#   2. 创建 API 密钥
#   3. 启用 YouTube Data API v3
#   4. 可选: 限制密钥仅用于 YouTube Data API v3
# 默认配额: 10,000 units/天 (免费)
YOUTUBE_API_KEY=your-youtube-api-key
# 浏览器模式代理(可选)
CB_YOUTUBE_PROXY=socks5://127.0.0.1:11080
